generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// PRE-BUILT — do not modify
model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  name      String
  createdAt DateTime  @default(now())
  bookings  Booking[]
}

// NEW
enum BookingStatus {
  ACTIVE
  CANCELLED
}

// NEW
model Room {
  id       Int       @id @default(autoincrement())
  name     String
  capacity Int
  bookings Booking[]
}

// NEW
model Booking {
  id        Int           @id @default(autoincrement())
  userId    Int
  roomId    Int
  date      String
  startTime String
  endTime   String
  status    BookingStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id])
  room      Room          @relation(fields: [roomId], references: [id])
}
